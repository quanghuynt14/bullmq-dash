{
  "name": "bullmq-dash",
  "version": "0.3.0",
  "description": "Terminal UI dashboard for BullMQ queue monitoring",
  "keywords": [
    "bullmq",
    "cli",
    "dashboard",
    "monitoring",
    "queue",
    "redis",
    "terminal",
    "tui"
  ],
  "homepage": "https://github.com/quanghuynt14/bullmq-dash#readme",
  "bugs": {
    "url": "https://github.com/quanghuynt14/bullmq-dash/issues"
  },
  "license": "MIT",
  "author": "quanghuynt14",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/quanghuynt14/bullmq-dash.git"
  },
  "bin": {
    "bullmq-dash": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "publishConfig": {
    "provenance": true
  },
  "scripts": {
    "dev": "bun src/index.ts",
    "build": "bun build.ts",
    "start": "bun dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt --write",
    "format:check": "oxfmt --check",
    "security:audit-0.2.7": "bun scripts/audit-socket-target.ts",
    "security:release": "bun run security:verify-source-control && bun run security:verify-lockfile && bun run security:verify-workflows && bun run security:verify-package && bun run security:score",
    "security:score": "bun scripts/socket-score.ts",
    "security:verify-lockfile": "bun scripts/lockfile-policy.ts",
    "security:verify-package": "bun scripts/verify-package.ts",
    "security:verify-source-control": "bun scripts/source-control-policy.ts",
    "security:verify-workflows": "bun scripts/workflow-policy.ts",
    "test": "bun test",
    "prepublishOnly": "bun run security:verify-source-control && bun run security:verify-lockfile && bun run security:verify-workflows && bun run security:verify-package",
    "prepack": "bun scripts/publish-manifest.ts prepack",
    "postpack": "bun scripts/publish-manifest.ts restore",
    "postpublish": "bun scripts/publish-manifest.ts restore"
  },
  "dependencies": {
    "@opentui/core": "^0.2.10",
    "bullmq": "^5.76.8"
  },
  "devDependencies": {
    "@types/bun": "1.3.13",
    "@types/node": "^25.6.2",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.63.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "packageManager": "bun@1.3.13"
}
