{
  "name": "bullmq-dash",
  "version": "0.2.3",
  "description": "Terminal UI dashboard for BullMQ queue monitoring",
  "keywords": [
    "bullmq",
    "cli",
    "dashboard",
    "monitoring",
    "queue",
    "redis",
    "terminal",
    "tui"
  ],
  "license": "MIT",
  "author": "quanghuynt14",
  "repository": {
    "type": "git",
    "url": "https://github.com/quanghuynt14/bullmq-dash"
  },
  "bin": {
    "bullmq-dash": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "dev": "bun src/index.ts",
    "build": "bun build.ts",
    "start": "bun dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt --write",
    "format:check": "oxfmt --check",
    "test": "bun test",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@fastify/websocket": "^11.2.0",
    "@opentui/core": "^0.1.87",
    "bullmq": "^5.71.0",
    "fastify": "^5.6.1",
    "ioredis": "^5.10.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "1.3.12",
    "@types/node": "^25.5.0",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.55.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "packageManager": "bun@1.3.10"
}
